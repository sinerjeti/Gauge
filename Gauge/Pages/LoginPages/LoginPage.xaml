<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gauge.Pages.LoginPages.LoginPage"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid 
        RowDefinitions="*, Auto"
        ColumnDefinitions="*"
        HorizontalOptions="Fill" 
        VerticalOptions="Fill" 
        Padding="20, 0, 20, 0">

        <VerticalStackLayout
            Grid.Row="0"
            Grid.Column="0"
            Spacing="15" 
            HorizontalOptions="Center" 
            VerticalOptions="Start">

            <Image 
                Source="applogo.png" 
                HeightRequest="200" 
                WidthRequest="200"
                Aspect="AspectFit"
                HorizontalOptions="Center" 
                Margin="0, 50, 0, 0"/>

            <Label 
                Text="Добро Пожаловать!"
                HorizontalOptions="Center"
                FontSize="28"
                FontAttributes="Bold"
                FontFamily="Comfortaa"/>

            <Label 
                x:Name="LoginStatusText"
                Text="Введите номер телефона, чтобы войти или зарегистрироваться."
                HorizontalOptions="Center"
                WidthRequest="300"
                FontSize="14"
                FontAttributes="Bold"
                FontFamily="Comfortaa"
                HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>

        <VerticalStackLayout 
            Grid.Row="1" 
            Grid.Column="0" 
            Spacing="15" 
            HorizontalOptions="Fill"
            VerticalOptions="End" 
            Margin="0, 0, 0, 20">

            <Border 
                Stroke="#2d0c98"
                StrokeThickness="2"
                StrokeShape="15"
                Padding="0"
                HorizontalOptions="Fill">

                <Entry 
                    Placeholder="+7 (905) 905-05-05"
                    x:Name="LoginNumber"
                    FontFamily="Comfortaa"
                    Margin="10, 0, 10, 0"
                    Keyboard="Numeric"
                    Completed="InLoginNextPage"/>
                <!--тут надо будет допилить анимку, ввод надо запретить, когда начнется анимка-->

            </Border>

            <Button 
                Text="Далее"
                TextColor="White"
                FontFamily="Comfortaa"
                BackgroundColor="#2d0c98"
                CornerRadius="15" 
                HeightRequest="50"
                HorizontalOptions="Fill"
                Clicked="InLoginNextPage"/>

        </VerticalStackLayout>

        <Label
            Grid.Row="1"
            Grid.Column="0"
            VerticalOptions="Start"
            HorizontalOptions="Center"
            Text=" Номер телефона "
            TextColor="#2d0c98"
            FontSize="12"
            FontAttributes="Bold"
            FontFamily="Comfortaa"
            TranslationY="-9"
            Background="White"/>

    </Grid>

</ContentPage>